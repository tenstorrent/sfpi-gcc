RVTT_FN (sfpselect4,         RISCV_XTT_VEC_FTYPE_XTT_VEC4_USI,                                 0x00, -1, -1, -1,      0, 0)

RVTT_VFN(sfpnop,             RISCV_VOID_FTYPE,                                                 0x00, -1, -1, -1,      0, 0)
