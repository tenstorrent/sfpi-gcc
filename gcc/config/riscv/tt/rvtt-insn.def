// The _lv instructions MUST follow the non-live versions of the same instruction

// FN returns a value (target)
// VFN doesn't return a value (void)
// PFN ensures that each arch has the same # insns (PAD aren't instanced)

#ifndef RVTT_FN
#define RVTT_FN(a, b, c, d, e, f, g, h)
#endif

#ifndef RVTT_VFN
#define RVTT_VFN(a, b, c, d, e, f, g, h) RVTT_FN (a, b, c, d, e, f, g, h)
#endif

#ifndef RVTT_WH_PFN
#define RVTT_WH_PFN(a)
#endif

#ifndef RVTT_WH_FN
#define RVTT_WH_FN(a, b, c, d, e, f, g, h)
#endif

#ifndef RVTT_WH_VFN
#define RVTT_WH_VFN(a, b, c, d, e, f, g, h) RVTT_WH_FN (a, b, c, d, e, f, g, h)
#endif

#ifndef RVTT_BH_PFN
#define RVTT_BH_PFN(a)
#endif

#ifndef RVTT_BH_FN
#define RVTT_BH_FN(a, b, c, d, e, f, g, h)
#endif

#ifndef RVTT_BH_VFN
#define RVTT_BH_VFN(a, b, c, d, e, f, g, h) RVTT_BH_FN (a, b, c, d, e, f, g, h)
#endif

// Note: each architecture MUST have the SAME NUMBER of entries in the SAME ORDER!
// This can be ensured by using the RVTT_PAD_XX define

// flags: see INSN_FLAGS in rvtt.h
// dst_arg_pos: which argument number contains the destination for src-as-dst insns, -1 otherwise
// mod_pos: which argument number contains the mod value
// schedule: non-zero if this instruction needs scheduling (nop pads), see INSN_SCHED_* in rvtt-protos.h
// nonimm_pos: argument position of the nonimm argument (runtime supplied immediate), -1 otherwise
// nonimm_mask: bit mask to get to the nonimm value (eg, 0xFFFF for 16 bit nonimm)
// nonimm_shft: shift to right justify the nonimm value

// Common builtin intrinsics.  args are (id, fmt, flags, dst_arg_pos, mod_pos, nonimm_pos, nonimm_mask, nonimm_shft)
RVTT_FN (synth_opcode,       RISCV_USI_FTYPE_USI_USI,                                          0x00, -1, -1, -1,      0, 0)

RVTT_FN (sfpxicmps,          RISCV_USI_FTYPE_XTT_IPTR_XTT_VEC_USI_USI_USI_USI,                 0x01, -1,  5,  2,      0, 0)
RVTT_FN (sfpxicmpv,          RISCV_USI_FTYPE_XTT_VEC_XTT_VEC_USI,                              0x01, -1,  2, -1,      0, 0)
RVTT_FN (sfpxbool,           RISCV_USI_FTYPE_USI_USI_USI,                                      0x00, -1, -1, -1,      0, 0)
RVTT_FN (sfpxcondi,          RISCV_XTT_VEC_FTYPE_USI,                                          0x00, -1, -1, -1,      0, 0)
RVTT_FN (sfpxvif,            RISCV_USI_FTYPE,                                                  0x00, -1, -1, -1,      0, 0)
