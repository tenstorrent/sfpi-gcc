RVTT_FN (sfpshft2_copy4,     RISCV_XTT_VEC4_FTYPE_XTT_VEC_XTT_VEC_XTT_VEC_USI,                 0x00, -1, 3, -1,       0, 0)
RVTT_FN (sfpshft2_subvec_copy4, RISCV_XTT_VEC4_FTYPE_XTT_VEC_XTT_VEC_XTT_VEC_XTT_VEC_USI,      0x00, -1, 4, -1,       0, 0)
