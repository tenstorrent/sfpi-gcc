RVTT_FN (sfpselect4,         ,,XTT_VEC_FTYPE_XTT_VEC4_USI,                                   0,  ({CU, 2}))

RVTT_FN (sfpsetcc_i,         ,,VOID_FTYPE_USI_USI,                                           CC(), ({U, 1}, {M, 0x102}))
RVTT_FN (sfpsetcc_v,         ,,VOID_FTYPE_XTT_VEC_USI,                                       CC(), ({M, 0x55}))
RVTT_FN (sfpencc,            ,,VOID_FTYPE_USI_USI,                                           CC(), ({U, 2}, {M, 0x707}))
RVTT_FN (sfpcompc,           ,,VOID_FTYPE,                                                   CC(), ())
// FIXME: sfppushc (13) inverts the current result reg" CC(0x2000)
RVTT_FN (sfppushc,           ,,VOID_FTYPE_USI,                                               0, ({M, 0xffff}))
RVTT_FN (sfppopc,            ,,VOID_FTYPE_USI,                                               CC(), ({M, 0xffff}))

// Make sure prior defn never needs to ask for live version, and make
// sure we never ask for the non-live version of this one.
RVTT_FN (sfpassign_lv,       ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC,                                LV,())

// Although sfpmov permitx 0x107 for mask bits, only 0x2 makes sense here -- all other cases should be expressed differently
RVTT_FN (sfpmov,             ,,XTT_VEC_FTYPE_XTT_VEC_USI,                                    0,           ({M, 0x2}))
RVTT_FN (sfpmov_lv,          ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC_USI,                            LV,      ({M, 0x2}))
RVTT_FN (sfpexexp,           ,,XTT_VEC_FTYPE_XTT_VEC_USI,                                    CC(0xf0c),      ({M, 0xf0f}))
RVTT_FN (sfpexexp_lv,        ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC_USI,                            LV|CC(0xf0c), ({M, 0xf0f}))
RVTT_FN (sfpexman,           ,,XTT_VEC_FTYPE_XTT_VEC_USI,                                    0,           ({M, 0x3}))
RVTT_FN (sfpexman_lv,        ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC_USI,                            LV,      ({M, 0x3}))
RVTT_FN (sfpabs,             ,,XTT_VEC_FTYPE_XTT_VEC_USI,                                    0,           ({M, 0x3}))
RVTT_FN (sfpabs_lv,          ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC_USI,                            LV,      ({M, 0x3}))
RVTT_FN (sfplz,              ,,XTT_VEC_FTYPE_XTT_VEC_USI,                                    CC(0x54),      ({M, 0x5555}))
RVTT_FN (sfplz_lv,           ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC_USI,                            LV|CC(0x54), ({M, 0x5555}))

RVTT_FN (sfpand,             ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC,                                CLB()|COM,  ())
RVTT_FN (sfpor,              ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC,                                CLB()|COM,  ())
RVTT_FN (sfpxor,             ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC,                                CLB()|COM,  ())
RVTT_FN (sfpnot,             ,,XTT_VEC_FTYPE_XTT_VEC,                                        0,           ())
RVTT_FN (sfpnot_lv,          ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC,                                LV,      ())

RVTT_FN (sfpshft_v,          ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC_USI,                            CLB(),  ({M, 0x1}))
