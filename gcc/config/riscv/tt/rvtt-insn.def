// The _lv instructions MUST follow the non-live versions of the same instruction

// FN defines a builtin
// OVR defines an override
#ifndef RVTT_FN
#define RVTT_FN(a, b, c, d, e, f)
#endif

#ifndef RVTT_OVR
#define RVTT_OVR(a, b, c, d, e, f)
#endif

#define LV rvtt_insn_data::HAS_LV
#define CC(N) (((N+0) ? (N + 0) : 0xffff) << rvtt_insn_data::CC_MASK_SHIFT)
#define CLB(N) (((N+0) << rvtt_insn_data::CLOBBER_SHIFT) | (1 << rvtt_insn_data::NUM_CLOBBERS_SHIFT))
#define CLB2(N) (CLB(N) + (1 << rvtt_insn_data::NUM_CLOBBERS_SHIFT))
#define COM rvtt_insn_data::COMMUTES

#define N rvtt_insn_data::op_t::NONE
#define R rvtt_insn_data::op_t::RUNTIME
#define M rvtt_insn_data::op_t::checked (rvtt_insn_data::op_t::MOD)
#define XM rvtt_insn_data::op_t::XMOD

#define U rvtt_insn_data::op_t::UNSIGNED
#define S rvtt_insn_data::op_t::SIGNED
#define E rvtt_insn_data::op_t::EITHER
#define CU rvtt_insn_data::op_t::checked (U)
#define CS rvtt_insn_data::op_t::checked (S)
#define CE rvtt_insn_data::op_t::checked (E)

// Args are (NAME, ISA, _SFX, TYPE, FLAGS, OPS)

// This is first
RVTT_FN (synth_opcode,       ,,USI_FTYPE_USI_USI,                                            0,  ({U, 0}, {U, 0}))

RVTT_FN (sfpxvif,            ,,USI_FTYPE,                                                    0, ())
RVTT_FN (sfpxbool,           ,,USI_FTYPE_USI_USI_USI,                                        0, ({U, 2}, {R}, {R}))
RVTT_FN (sfpxcondb,          ,,VOID_FTYPE_USI_USI,                                           0, ({R}, {R}))
RVTT_FN (sfpxcondi,          ,,XTT_VEC_FTYPE_USI,                                            0, ({R}, {}))
RVTT_FN (sfpxicmps,          ,,USI_FTYPE_XTT_IPTR_XTT_VEC_USI_USI_USI_USI,                   CC(), ({E, 0}, {XM}))
RVTT_FN (sfpxicmpv,          ,,USI_FTYPE_XTT_VEC_XTT_VEC_USI,                                CC(), ({XM}, {}))
RVTT_FN (sfpxfcmps,          ,,USI_FTYPE_XTT_IPTR_XTT_VEC_USI_USI_USI_USI,                   CC(), ({U, 0}, {XM}))
RVTT_FN (sfpxfcmpv,          ,,USI_FTYPE_XTT_VEC_XTT_VEC_USI,                                CC(), ({XM}, {}))
RVTT_FN (sfpxloadi,          ,,XTT_VEC_FTYPE_XTT_IPTR_USI_USI_USI_USI,                       0, ({E, 16}, {XM}))
RVTT_FN (sfpxloadi_lv,       ,,XTT_VEC_FTYPE_XTT_IPTR_XTT_VEC_USI_USI_USI_USI,               LV, ({E, 16, 0, 0, true}, {XM}))
RVTT_FN (sfpxiadd_v,         ,,XTT_VEC_FTYPE_XTT_VEC_XTT_VEC_USI,                            CLB()|CC(0x7e7e),  ({XM, 0x7f}, {}))
RVTT_FN (sfpxiadd_i,         ,,XTT_VEC_FTYPE_XTT_IPTR_XTT_VEC_USI_USI_USI_USI,               CC(0x7e7e), ({E, 0}, {XM}))
RVTT_FN (sfpxiadd_i_lv,      ,,XTT_VEC_FTYPE_XTT_IPTR_XTT_VEC_XTT_VEC_USI_USI_USI_USI,       LV|CC(0x7e7e), ({E, 0}, {XM}))

RVTT_FN (sfpnop,             ,,VOID_FTYPE,                                                   0, ())

RVTT_FN (sfpreadlreg,        ,,XTT_VEC_FTYPE_USI,                                            0,  ({CU, 4}))
RVTT_FN (sfpwritelreg,       ,,VOID_FTYPE_XTT_VEC_USI,                                       0,  ({CU, 3}))

RVTT_FN (sfpnovalue,         ,,XTT_VEC_FTYPE,                                                0,  ())
