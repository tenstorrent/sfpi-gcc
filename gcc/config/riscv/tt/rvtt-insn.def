RVTT_VFN(ttincrwc,           RISCV_VOID_FTYPE_USI_USI_USI_USI,                                 0x00, -1, -1, -1,      0, 0)
// The length operand is [1,32], which is awkward
RVTT_VFN(ttreplay,           RISCV_VOID_FTYPE_XTT_IPTR_USI_USI_USI_USI_USI_USI,                0x00, -1, -1,  1, (unsigned)-1, 4)

