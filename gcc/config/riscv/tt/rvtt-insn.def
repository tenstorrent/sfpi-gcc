// Make sure the last defn is never something we ask for get-live-version of.

#undef LV
#undef CC
#undef CLB
#undef CLB2
#undef COM

#undef N
#undef R
#undef M
#undef XM

#undef U
#undef S
#undef E
#undef CU
#undef CS
#undef CE

#undef RVTT_FN
#undef RVTT_OVR
