RVTT_FN (sfpshft_i,          ,,XTT_VEC_FTYPE_XTT_IPTR_XTT_VEC_SI_USI_USI_USI,                CLB(),  ({S, 12, 12}, {M, 0x1}))
RVTT_OVR(sfpshft_i,        bh,,XTT_VEC_FTYPE_XTT_IPTR_XTT_VEC_SI_USI_USI_USI,                0,       ({S, 12, 12}, {M, 0x5}))
#if 0 // Not ready yet
RVTT_FN (sfpshft_i_lv,  bh,bh_,XTT_VEC_FTYPE_XTT_IPTR_XTT_VEC_XTT_VEC_SI_USI_USI_USI,        LV,  ({S, 12, 12}, {M, 0x5}))
