RVTT_FN (sfpload,            wh,,XTT_VEC_FTYPE_XTT_IPTR_USI_USI_USI_USI_USI,                 0, ({CE, 14}, {M, 0xf7ff}, {CU, 2}))
RVTT_OVR(sfpload,            bh,,XTT_VEC_FTYPE_XTT_IPTR_USI_USI_USI_USI_USI,                 0, ({CE, 13}, {M, 0xf7cf}, {CU, 3}))
RVTT_FN (sfpload_lv,         wh,,XTT_VEC_FTYPE_XTT_IPTR_XTT_VEC_USI_USI_USI_USI_USI,         LV, ({CE, 14}, {M, 0xf7ff}, {CU, 2}))
